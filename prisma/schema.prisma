generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. Enums ---
enum Role {
  EMPLOYEE
  MANAGER
}

enum NoticeType {
  URGENT
  SUCCESS
  INFO
}

enum NoticeCategory {
  COMPANY
  PROJECTS
  EVENTS
}

enum ReportStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

// --- 2. User Model ---
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  password         String?
  role             Role      @default(EMPLOYEE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  department       String?   @default("DX")

  projects         Project[]
  
  messages         Message[] @relation("UserMessages") 
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  assignedTasks    Task[]    @relation("TaskAssignee")
  reports          Report[] 
  comments         Comment[] 
  reactions        Reaction[] 
  notices          Notice[]
}

// --- 3. Project Model ---
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("進行中")
  startDate   DateTime?
  endDate     DateTime?
  driveLink   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     User[]
  messages    Message[]
  tasks       Task[]
}

// --- 4. Task Model ---
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") 
  priority    String    @default("MEDIUM") 
  dueDate     DateTime?

  checklist   Json?     @default("[]")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])

  reports     Report[] 
}

// --- 5. Updated Chat Message Model ---
model Message {
  id          String   @id @default(cuid())
  text        String   @db.Text
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)

  // 1. For Project Chat
  projectId   String?  
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User     @relation("UserMessages", fields: [authorId], references: [id], onDelete: Cascade)

  // 2. For Direct Messaging (FIXED: Added '?' so it doesn't break Project Chats)
  senderId      String?   
  sender        User?     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId    String?  
  receiver      User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])

  reactions   Reaction[]
  
  @@index([authorId])
  @@index([senderId])
  @@index([receiverId])
  @@index([projectId])
}

// --- 7. Report & Feedback Models ---
model Report {
  id        String       @id @default(cuid())
  content   String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())

  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  
  taskId    String?      
  task      Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  comments  Comment[]
}

model Comment {
  id        String    @id @default(cuid())
  text      String
  createdAt DateTime  @default(now())

  reportId  String
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  reactions Reaction[] 
}

// --- 8. Reaction Model (For Emojis) ---
model Reaction {
  id        String   @id @default(cuid())
  emoji     String   
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

// --- 9. Notice/Broadcast Model ---
model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String   
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}