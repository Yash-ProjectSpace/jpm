generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NEW: 1. Role Enum ---
enum Role {
  EMPLOYEE
  MANAGER
}

// --- 2. User Model (Updated with Role) ---
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  department    String?   @default("DX")

  projects      Project[]
  messages      Message[]
  assignedTasks Task[]    @relation("TaskAssignee")

  // --- ADD THESE TWO LINES ---
  reports  Report[] // Opposite relation for Report.author
  comments Comment[] // Opposite relation for Comment.author
}

// --- 3. Project Model ---
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("進行中")
  startDate   DateTime?
  endDate     DateTime?
  driveLink   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members  User[]
  messages Message[]

  tasks Task[]
}

// --- 4. Task Model ---
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?

  checklist Json? @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

// --- 5. Chat Message Model ---
model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- 6. Notice/Broadcast Models ---
enum NoticeType {
  URGENT
  SUCCESS
  INFO
}

// ADD THIS ENUM
enum NoticeCategory {
  COMPANY
  PROJECTS
  EVENTS
}

model Notice {
  id        String         @id @default(cuid())
  type      NoticeType     @default(INFO)
  category  NoticeCategory @default(COMPANY) // ADD THIS LINE
  title     String
  createdAt DateTime       @default(now())
}

// --- Report & Feedback Models ---

model Report {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  comments  Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  // Relations
  reportId  String
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
}