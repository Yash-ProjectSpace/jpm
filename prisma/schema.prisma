generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. User Model (Updated with Task relations) ---
model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  password  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]
  messages  Message[]
  
  // NEW: Tasks assigned to this specific user
  assignedTasks Task[]   @relation("TaskAssignee")
}

// --- 2. Project Model (Updated with Task relation) ---
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("進行中") 
  startDate   DateTime?
  endDate     DateTime?
  driveLink   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members  User[] 
  messages Message[] 
  
  // NEW: A project can have many tasks
  tasks    Task[]
}

// --- 3. NEW: Task Model (The Core of your request) ---
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?
  
  // Multi-step Checklist stored as a JSON array 
  // Structure: [{ "text": "Step 1", "completed": false }]
  checklist   Json?     @default("[]")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Connects task to a specific Project
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Connects task to a specific User (Assignee)
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

// --- 4. Chat Message Model ---
model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}